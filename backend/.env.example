CORS_ORIGINS=http://localhost:5173
DATABASE_PATH=cloudpulse.db
AWS_REGION=us-east-1

# For SaaS mode: hardcode the CloudPulse backend's AWS principal
# This is shown in the "Create IAM Role" wizard so customers know which account to trust
# For local testing: leave empty to auto-detect from boto3 credentials
SAAS_AWS_ACCOUNT_ID=
SAAS_AWS_PRINCIPAL_ARN=

# Note: The IAM role needs these permissions:
# - ec2:DescribeVolumes (for unattached EBS volumes check)
# - ec2:DescribeAddresses (for unattached EIPs check)
# - ec2:DescribeInstances (for stopped EC2 instances check)
# - ec2:DescribeRegions (to list regions)
# The connection wizard will show the exact policy to use
